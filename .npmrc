# pnpm only — see docs/rules.md.
# NOTE: engine-strict is OFF. A workspace `pnpm install` resolves every app's
# deps, so the desktop app's electron (Node >= 22.12) would hard-fail an install
# on a Node 20 host (e.g. Railway, which deploys only the backend). With strict
# off, pnpm warns on engine mismatches instead of failing. Re-enable only if you
# also scope production installs per-app (e.g. `pnpm --filter <app>...`).
engine-strict=false

# Refuse any package version published less than 7 days ago.
# Cheap defence against fresh supply-chain attacks. Do not lower without reason.
minimum-release-age=10080
