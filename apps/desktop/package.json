{
  "name": "@leaksync/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "predev": "pkill -9 -f 'leaksync.*[Ee]lectron' || true",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "kill": "pkill -9 -f 'leaksync.*[Ee]lectron' || true",
    "build": "electron-vite build",
    "start": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "dist": "electron-vite build && electron-builder --mac --arm64 --x64",
    "dist:arm64": "electron-vite build && electron-builder --mac --arm64",
    "dist:x64": "electron-vite build && electron-builder --mac --x64",
    "package": "electron-vite build && electron-builder --mac --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --config ../../eslint.config.mjs 'src/**/*.{ts,tsx}'"
  },
  "build": {
    "appId": "com.leaksync.desktop",
    "productName": "LeakSync",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "identity": null,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "LeakSync"
    }
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@leaksync/api": "workspace:*",
    "@leaksync/core": "workspace:*",
    "@leaksync/ui": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.3.3",
    "electron-builder": "^26.14.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.8.3",
    "vite": "^6.0.0"
  }
}
