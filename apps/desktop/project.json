{
  "name": "desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/desktop/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm dev", "cwd": "apps/desktop" }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm build", "cwd": "apps/desktop" },
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/out"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm typecheck", "cwd": "apps/desktop" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm lint", "cwd": "apps/desktop" }
    }
  },
  "tags": ["scope:desktop", "type:app"],
  "implicitDependencies": ["ui", "core", "api"]
}
