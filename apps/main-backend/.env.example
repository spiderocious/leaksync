NODE_ENV=development
PORT=9090
LOG_LEVEL=info

APP_BASE_URL=http://localhost:9090
WEB_BASE_URL=*

# MongoDB — pairs + items. Point at your local instance.
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=leaksync

# Signs the long-lived device JWTs used for pairing (no accounts). >= 32 chars.
DEVICE_JWT_SECRET=replace_me_with_a_long_random_string_at_least_32_chars

# Legacy auth-stub secrets (template's auth feature; LeakSync pairing ignores them).
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
