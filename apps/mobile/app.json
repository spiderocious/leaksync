{
  "expo": {
    "name": "LeakSync",
    "slug": "leaksync",
    "scheme": "leaksync",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": ["android"],
    "android": {
      "package": "com.leaksync.app",
      "edgeToEdgeEnabled": true,
      "permissions": ["READ_MEDIA_IMAGES", "READ_MEDIA_VIDEO"]
    },
    "ios": {
      "bundleIdentifier": "com.leaksync.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "LeakSync needs access to your photos so you can send images to your Mac.",
          "cameraPermission": "LeakSync needs the camera so you can send a photo to your Mac."
        }
      ],
      [
        "expo-share-intent",
        {
          "androidIntentFilters": ["text/*", "image/*", "video/*"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
