{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "paths": {
      "@app/*": ["./src/*"],
      "@leaksync/core": ["../../packages/core/src/index.ts"],
      "@leaksync/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src", "app", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
